#!/usr/bin/env bash
# Displays information about subdomains

# shellcheck disable=SC2086
display_info() {
    local domain=$1
    local subdomain=$2
    local record
    
    # Query dig and extract the record line. We use grep -v '^;' to ignore comments if needed.
    record=$(dig "${subdomain}.${domain}" | grep -A1 "ANSWER SECTION:" | tail -n 1)
    
    # Extract record type ($4) and destination ($5) using awk.
    # Handling cases where record might be empty or malformed.
    local record_type
    record_type=$(echo "$record" | awk '{print $4}')
    local destination
    destination=$(echo "$record" | awk '{print $5}')
    
    # Only echo if record_type is found, otherwise it means DNS look up failed.
    # But for the task, we should follow the exact format even if empty?
    # Actually, the task says "You do not need to handle edge cases... Nonexistent subdomains"
    # So we strictly follow the format.
    echo "The subdomain ${subdomain} is a ${record_type} record and points to ${destination}"
}

domain=$1
subdomain=$2

if [ -z "$subdomain" ]; then
    display_info "$domain" "www"
    display_info "$domain" "lb-01"
    display_info "$domain" "web-01"
    display_info "$domain" "web-02"
else
    display_info "$domain" "$subdomain"
fi
